`timescale 1ns/1ps

module two_bitadder_tb;

    reg  [1:0] a, b;
    wire gt, lt, et;

    // Instantiate the DUT (Device Under Test)
    two_bitadder uut (
        .a(a),
        .b(b),
        .gt(gt),
        .lt(lt),
        .et(et)
    );

    integer i, j;

    initial begin
        $display("Time\tA\tB\tGT\tLT\tET");
        $display("--------------------------------");

        for (i = 0; i < 4; i = i + 1) begin
            for (j = 0; j < 4; j = j + 1) begin
                a = i;
                b = j;
                #10;
                $display("%0t\t%b\t%b\t%b\t%b\t%b",
                         $time, a, b, gt, lt, et);
            end
        end

        #10;
        $finish;
    end

endmodule
